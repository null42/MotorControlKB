	"C:/ti/ti-cgt-c2000_16.9.0.LTS/bin/cl2000" -v28 -ml -mt --cla_support=cla0 -Ooff --fp_reassoc=off --advice:performance=all --define=_INLINE --define=VER="\"20211029_0856\"" --diag_warning=225 --diag_wrap=off --display_error_number -z -m"hf_motordrive.map" --stack_size=0x300 --warn_sections -i"C:/ti/ti-cgt-c2000_16.9.0.LTS/lib" -i"F:/FOC/HFI/TI_hfi +esmo/DSP2803x_common/lib" -i"C:/ti/ti-cgt-c2000_16.9.0.LTS/include" --reread_libs --diag_wrap=off --display_error_number --xml_link_info="hf_motordrive_linkInfo.xml" --rom_model -o "hf_motordrive.out" $(ORDERED_OBJS)
